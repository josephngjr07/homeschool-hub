// Prisma schema — the single source of truth for your database shape.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Auth.js (NextAuth) models -------------------------------------------
// These four models are required by the Auth.js Prisma adapter. Google
// sign-in writes a User + an Account; database sessions live in Session.

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  children      Child[]
  tasks         Task[]
}

// --- Domain models --------------------------------------------------------

// A kid the parent homeschools. In the UI a Child is primarily a colored
// tag/filter on Tasks (name + color), not a profile to manage. Always scoped
// to its owning User — a parent only ever sees their own children.
model Child {
  id        String   @id @default(cuid())
  name      String
  color     String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks  Task[]

  @@index([userId])
}

// A planned learning activity for a specific day, assigned to one or more
// Children, checked off when done. "Everyone" is represented by linking the
// Task to all of the parent's current children — one Task row, never one per
// child. Unfinished Tasks silently stay on their date (ADR-0001): no overdue
// state lives here; "missed" is computed at read time, never stored.
model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime @db.Date
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  children Child[]

  @@index([userId, date])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
